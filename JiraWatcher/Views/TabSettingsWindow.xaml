<Window x:Class="JiraWatcher.TabSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Tab Settings" Height="340" Width="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded"
        Background="{DynamicResource MaterialDesignPaper}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Tab Settings" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

        <materialDesign:Card Grid.Row="1" Background="{DynamicResource MaterialDesignCardBackground}">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Tab Name" VerticalAlignment="Center" Margin="0,0,12,12"/>
                <TextBox x:Name="TabNameTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,12"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="JQL Search" VerticalAlignment="Top" Margin="0,4,12,0"/>
                <TextBox x:Name="TabJqlTextBox" Grid.Row="1" Grid.Column="1"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </materialDesign:Card>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Button Content="Delete Tab"
                    Click="DeleteButton_Click"
                    HorizontalAlignment="Left"
                    Foreground="#EF5350"
                    Style="{StaticResource MaterialDesignOutlinedButton}"/>
            <Button Content="Save"
                    Click="SaveButton_Click"
                    HorizontalAlignment="Right"/>
        </Grid>
    </Grid>
</Window>
